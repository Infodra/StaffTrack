# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# Development: Use local MongoDB
# Production: Use MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/gps_attendance?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=7d

# Geofence Configuration (in meters)
DEFAULT_GEOFENCE_RADIUS=100

# Company Office Location (Default - can be overridden per company)
DEFAULT_OFFICE_LATITUDE=0.0
DEFAULT_OFFICE_LONGITUDE=0.0

# Multi-Tenant Configuration
# Base domain for tenant subdomains
BASE_DOMAIN=tecinfo.st.infodra.ai
API_DOMAIN=api.infodra.ai

# CORS Configuration
# Development: localhost allowed
# Production: *.st.infodra.ai allowed
CORS_ORIGIN=http://localhost:3000
